{
  "NodeControl": {
    "DataProtection": {
      "ApplicationName": "NodeControl",
      "KeyRingPath": ".nodecontrol/data-protection-keys"
    },
    "Execution": {
      "RunWorkspaceRoot": ".nodecontrol/runs",
      "AnsiblePlaybookPath": "ansible-playbook",
      "RemoteAnsiblePlaybookPath": "ansible-playbook",
      "AllowLocalControlNodeExecution": true,
      "LocalControlNodeHostnames": [ "localhost", "127.0.0.1", "::1" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
